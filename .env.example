# Volva Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# API Keys (required for full functionality)
# =============================================================================

# Financial Modeling Prep API Key (https://site.financialmodelingprep.com/)
# Used for: Market data ingestion, stock prices, financial indicators
FMP_API_KEY=

# FRED API Key (https://fred.stlouisfed.org/docs/api/api_key.html)
# Used for: Economic indicator data (GDP, unemployment, inflation, etc.)
FRED_API_KEY=

# =============================================================================
# Optional API Keys
# =============================================================================

# Grok API Key (for advanced causal reasoning)
# Used for: Additional LLM-based analysis (optional)
GROK_API_KEY=

# Google AI / Gemini API Key (https://makersuite.google.com/app/apikey)
# Used for: Causal link discovery, prediction generation, judgement verification
GOOGLE_AIS_API_KEY=

# =============================================================================
# Runtime Configuration
# =============================================================================

# SurrealDB Connection (defaults shown)
# SURREALDB_HOST=http://127.0.0.1:8001
# SURREALDB_NS=volva
# SURREALDB_DB=causal_graph

# Logging
# DRY_RUN=true  # Set to false for production writes
# PYTHONUNBUFFERED=1  # For real-time log output
